# Pinata IPFS
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret
PINATA_JWT=your_pinata_jwt

# Sepolia testnet (never commit real keys)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_PRIVATE_KEY=your_sepolia_private_key_without_0x

# Optional: use existing Remix deployment instead of auto-deploy
REMIX_CONTRACT_ADDRESS=
REMIX_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Network mode: sepolia | local
NETWORK=sepolia
